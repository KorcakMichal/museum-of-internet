# OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Model to use (default: anthropic/claude-3.5-sonnet). Browse models at https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Your site URL sent in the HTTP-Referer header (optional, helps OpenRouter analytics)
SITE_URL=http://localhost:3000

# Port the server listens on (default: 3000)
PORT=3000
